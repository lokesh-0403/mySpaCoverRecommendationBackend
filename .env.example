SERVER_PORT=8080
APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
APP_STORAGE_ROOT=/app/data

INVENTORY_API_BASE_URL=https://inventory-api.myspacover.com
INVENTORY_API_LOGIN_ENDPOINT=/auth/login/web
INVENTORY_API_INVENTORY_ENDPOINT=/inventory/inhand-quantity
INVENTORY_API_LOGIN_EMAIL=
INVENTORY_API_LOGIN_PASSWORD=
INVENTORY_API_WEBHOOK_KEY=

INVENTORY_API_CONNECT_TIMEOUT=10s
INVENTORY_API_READ_TIMEOUT=60s
APP_MAX_PARALLEL_JOBS=4
APP_MAX_FILE_SIZE=10MB
APP_MAX_REQUEST_SIZE=10MB
APP_ASYNC_REQUEST_TIMEOUT=300000
